# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The application reads these via os.getenv() in src/config.py.
# Docker Compose also picks up a .env file automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── MLflow ───────────────────────────────────────────────────────────────────
# For local filesystem tracking (default):
MLFLOW_TRACKING_URI=file://./mlruns

# For a remote MLflow server (e.g., Docker Compose service):
# MLFLOW_TRACKING_URI=http://mlflow:5000

MLFLOW_EXPERIMENT_NAME=iris-classifier

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ──────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
